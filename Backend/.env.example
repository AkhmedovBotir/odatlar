APP_ENV=development
APP_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=odatlar_bot
DB_SSLMODE=disable

JWT_SECRET=change-this-to-a-long-random-secret-key-in-production
